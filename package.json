{
  "name": "alis-form-markup-assistant",
  "version": "0.1.0",
  "description": "Template Mapping & Orchestration Engine for ALIS PDF form field configuration",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/server.js",
    "client:dev": "cd client && cross-env PORT=3001 npm start",
    "build": "cd client && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ALIS",
    "PDF",
    "form",
    "markup",
    "template",
    "compliance"
  ],
  "author": "Aaron Whitmer <aaron@go-alis.com>",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "pdf-lib": "^1.17.1",
    "tesseract.js": "^4.1.1",
    "fuse.js": "^7.0.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
